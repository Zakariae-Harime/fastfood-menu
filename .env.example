# Copy this file to .env.local for local development.
# On Vercel: Project Settings -> Environment Variables -> add the same two.

# Airtable personal access token, scoped to data.records:read on the
# Snack Maestro base only. Create at https://airtable.com/create/tokens
AIRTABLE_TOKEN=

# The base ID (starts with "app..."), found in Airtable's API docs for
# your base: open the base, then Help -> API documentation.
AIRTABLE_BASE_ID=
